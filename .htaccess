AuthType Basic
AuthName "Dental Studio — технічне обслуговування"
AuthUserFile /home2/holiday8/dentstudio.in.ua/.htpasswd
Require valid-user

RewriteEngine On

# Remove index.html from URL
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

RewriteRule ^api/(.*)$ api.php?path=$1 [QSA,L]
